{
  "name": "xcode-mcp",
  "version": "2.0.0",
  "description": "Enhanced MCP server for comprehensive Xcode integration",
  "main": "build/index.js",
  "type": "module",
  "bin": {
    "xcode-mcp": "./build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf build coverage",
    "start": "node build/index.js",
    "dev": "tsc && node build/index.js",
    "watch": "tsc --watch",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'",
    "typecheck": "tsc --noEmit",
    "prebuild": "npm run clean",
    "postbuild": "chmod +x build/index.js",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "xcode",
    "ios",
    "macos",
    "swift",
    "simulator",
    "development",
    "tooling",
    "automation"
  ],
  "author": "Xcode MCP Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/xcode-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/xcode-mcp/issues"
  },
  "homepage": "https://github.com/yourusername/xcode-mcp#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.7.0",
    "prettier": "^3.0.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "build/**/*",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "publishConfig": {
    "access": "public"
  }
}
